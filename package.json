{
  "name": "doot-doot-revolution",
  "version": "2.0.0",
  "private": true,
  "description": "Browser rhythm game in the DDR and StepMania tradition, built as a workspace of small libraries.",
  "type": "module",
  "license": "MIT",
  "author": "Moheeb Zara",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "node --test packages/*/test/*.test.js",
    "test:web": "npm --workspace @doot-games/web run test",
    "test:all": "npm test && npm run test:web",
    "dev": "npm --workspace @doot-games/web run dev",
    "dev:desktop": "npm --workspace @doot-games/web run dev:desktop",
    "build": "npm --workspace @doot-games/web run build",
    "build:desktop": "npm --workspace @doot-games/web run build:desktop"
  },
  "engines": {
    "node": ">=20"
  }
}
