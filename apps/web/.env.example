# Optional web import routing. Read at build time by Vite and baked into the web
# bundle, so set these in your deploy's build-time environment. Both are ignored by
# the desktop app, which fetches and rips locally.

# CORS proxy prefix for importing a DIRECT audio URL from the browser (past the CORS
# wall). The target URL is appended as-is, e.g. with
#   VITE_CORS_PROXY=https://proxy.corsfix.com/?
# a request goes to  https://proxy.corsfix.com/?<audioUrl>. A proxy only forwards a
# request; it CANNOT rip YouTube.
VITE_CORS_PROXY=

# yt-dlp backend for importing YouTube links from the browser. The app requests
#   <VITE_YT_ENDPOINT>?url=<youtubeUrl>
# and expects audio bytes back, the title in an X-Video-Title header, and the mime in
# Content-Type. A deployable reference lives in server/youtube/.
VITE_YT_ENDPOINT=
